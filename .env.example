# ScrcpyX Environment Variables

# ADB Path (optional - will use system PATH if not set)
# VITE_ADB_PATH=/path/to/adb

# scrcpy Path (optional - will use system PATH if not set)
# VITE_SCRCPY_PATH=/path/to/scrcpy

# Development settings
VITE_DEV_SERVER_PORT=1420

# App settings
VITE_APP_NAME=ScrcpyX
